# Cursor
cursor-style = "block"
cursor-style-blink = false

# Quality of life
app-notifications = no-clipboard-copy
right-click-action = copy-or-paste
shell-integration-features = no-cursor,ssh-env

# Text rendering
font-family = "JetBrainsMono Nerd Font"

# Window
window-padding-balance = true
window-padding-x = 8
window-padding-y = 8
window-width = 120
window-height = 40
